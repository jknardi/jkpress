<%- include('partials/header', { title: siteTitle, desc: siteDesc }) %>

<main class="max-w-6xl mx-auto px-4 py-12">
    <div class="mb-10 text-center md:text-left">
        <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight sm:text-5xl">Kabar Berita Terkini</h1>
        <p class="mt-3 text-lg text-slate-500">Informasi pers akurat dan berkinerja tinggi tanpa kompromi.</p>
    </div>

    <!-- Grid Berita -->
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        <% posts.forEach(post => { %>
            <article class="bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-100 hover:shadow-md transition duration-300 flex flex-col">
                <% if(post.featured_image) { %>
                    <img class="h-48 w-full object-cover" src="<%= post.featured_image %>" alt="<%= post.title %>">
                <% } else { %>
                    <div class="h-48 w-full bg-slate-200 flex items-center justify-center text-slate-400">No Image</div>
                <% } %>
                <div class="p-6 flex-1 flex flex-col justify-between">
                    <div>
                        <h2 class="text-xl font-bold text-slate-900 hover:text-blue-600 transition mb-2">
                            <a href="/posts/<%= post.slug %>"><%= post.title %></a>
                        </h2>
                        <p class="text-slate-500 text-sm line-clamp-3 mb-4"><%= post.summary %></p>
                    </div>
                    <div class="text-xs text-slate-400 font-medium">
                        <%= new Date(post.created_at).toLocaleDateString('id-ID', { dateStyle: 'long' }) %>
                    </div>
                </div>
            </article>
        <% }) %>
    </div>
</main>

<%- include('partials/footer') %>
