<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'JkPress CMS' %></title>
    <meta name="description" content="<%= typeof desc !== 'undefined' ? desc : '' %>">
    
    <!-- Tailwind CSS untuk tampilan modern kekinian -->
    <script src="https://tailwindcss.com"></script>
    
    <!-- Injeksi Otomatis JSON-LD jika berada di halaman single post (Sangat Disukai Google & AI) -->
    <% if (typeof schemaJson !== 'undefined') { %>
        <script type="application/ld+json">
            <%- schemaJson %>
        </script>
    <% } %>
</head>
<body class="bg-slate-50 text-slate-800 font-sans antialiased">
    <nav class="bg-white border-b border-slate-200 sticky top-0 z-50 shadow-sm backdrop-blur-md bg-white/90">
        <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
            <a href="/" class="text-2xl font-black tracking-tight text-slate-900 bg-gradient-to-r from-blue-600 to-indigo-600 bg-clip-text text-transparent">JkPress.</a>
            <div class="flex gap-4 text-sm font-medium text-slate-600">
                <a href="/sitemap.xml" target="_blank" class="hover:text-blue-600 transition">Sitemap</a>
                <a href="/feed.xml" target="_blank" class="hover:text-blue-600 transition">RSS Feed</a>
            </div>
        </div>
    </nav>
