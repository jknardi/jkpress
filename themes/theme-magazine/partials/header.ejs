<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'JkPress Magazine' %></title>
    <meta name="description" content="<%= typeof desc !== 'undefined' ? desc : '' %>">
    
    <!-- Ultra-fast local Tailwind CSS v4 -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Premium Editorial Fonts -->
    <link rel="preconnect" href="https://googleapis.com">
    <link rel="preconnect" href="https://gstatic.com" crossorigin>
    <link href="https://googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
        .font-serif { font-family: 'Playfair Display', serif; }
    </style>

    <% if (typeof schemaJson !== 'undefined') { %>
        <script type="application/ld+json"><%- schemaJson %></script>
    <% } %>
</head>
<body class="bg-[#f4f7f5] text-stone-800 antialiased selection:bg-emerald-800 selection:text-white">

    <!-- Elegant Green-White Header -->
    <header class="border-b border-emerald-100 bg-white/90 backdrop-blur-md sticky top-0 z-50 shadow-xs">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            
            <!-- Logo Branding -->
            <a href="/" class="font-serif text-2xl md:text-3xl font-black tracking-tight text-emerald-950 uppercase flex items-center gap-2">
                <span class="bg-emerald-800 text-white px-2 py-0.5 rounded-xs text-xl md:text-2xl font-sans font-bold">JK</span>
                <span class="border-b-2 border-emerald-800 pb-0.5">PRESS</span>
            </a>
            
            <!-- Premium Menu Navigation -->
            <nav class="hidden md:flex items-center gap-8 text-xs font-bold tracking-widest uppercase">
                <a href="/" class="text-emerald-900 hover:text-emerald-600 transition duration-200 relative after:content-[''] after:absolute after:w-full after:scale-x-100 after:h-0.5 after:bottom-[-4px] after:left-0 after:bg-emerald-700">Home</a>
                <a href="#" class="text-stone-600 hover:text-emerald-700 transition duration-200">Politics</a>
                <a href="#" class="text-stone-600 hover:text-emerald-700 transition duration-200">Tech & AI</a>
                <a href="#" class="text-stone-600 hover:text-emerald-700 transition duration-200">Environment</a>
                <a href="/sitemap.xml" target="_blank" class="bg-emerald-50 text-emerald-800 px-3 py-1.5 rounded-sm hover:bg-emerald-800 hover:text-white transition duration-300">Sitemap</a>
            </nav>

            <!-- Mobile Menu Icon (Visual Only) -->
            <div class="md:hidden text-emerald-950 cursor-pointer">
                <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                </svg>
            </div>
        </div>
    </header>
